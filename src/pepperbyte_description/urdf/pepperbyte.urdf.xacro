<?xml version="1.0"?>
<!-- Copyright (c) 2026 Peppermint Robotics. All rights reserved. -->
<!--
  Master URDF for PepperByte — Waveshare Cobra Flex 4WD chassis.
  All geometry is split into per-subsystem xacro files included below.
  Dimensions from Waveshare Cobra Flex datasheet (rev. 2026-03).
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="pepperbyte">

  <!-- ================================================================
       Shared properties — available to all included files
       ================================================================ -->

  <!-- Chassis: 235 x 173 x 101 mm (L x W x H) -->
  <xacro:property name="chassis_length"    value="0.235"/>
  <xacro:property name="chassis_width"     value="0.173"/>
  <xacro:property name="chassis_height"    value="0.101"/>
  <xacro:property name="chassis_mass"      value="2.375"/>

  <!-- Wheel geometry -->
  <xacro:property name="wheel_radius"      value="0.03725"/>   <!-- 74.5mm diameter -->
  <xacro:property name="wheel_width"       value="0.030"/>
  <xacro:property name="wheel_mass"        value="0.200"/>

  <!-- Drive geometry -->
  <xacro:property name="track_width"       value="0.2285"/>    <!-- 228.5mm centre-to-centre -->
  <xacro:property name="wheelbase"         value="0.154"/>     <!-- 154mm front-to-rear axle -->
  <xacro:property name="ground_clearance"  value="0.03424"/>   <!-- 34.24mm -->

  <!-- Sensor placement -->
  <xacro:property name="lidar_height"      value="0.150"/>     <!-- above base_link -->
  <xacro:property name="camera_height"     value="0.100"/>     <!-- above base_link -->
  <xacro:property name="camera_tilt"       value="${-pi/4}"/>  <!-- -45 deg pitch -->

  <!-- ================================================================
       Materials
       ================================================================ -->
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.2 0.8 0.2 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>

  <!-- ================================================================
       Sub-system includes
       ================================================================ -->
  <xacro:include filename="$(find pepperbyte_description)/urdf/chassis.xacro"/>
  <xacro:include filename="$(find pepperbyte_description)/urdf/wheels.xacro"/>
  <xacro:include filename="$(find pepperbyte_description)/urdf/lidar.xacro"/>
  <xacro:include filename="$(find pepperbyte_description)/urdf/imu.xacro"/>
  <xacro:include filename="$(find pepperbyte_description)/urdf/camera.xacro"/>
  <xacro:include filename="$(find pepperbyte_description)/urdf/gazebo.xacro"/>

</robot>
